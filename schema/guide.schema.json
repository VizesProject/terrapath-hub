{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://terrapath.example/schema/guide.schema.json",
  "title": "TerraPath Guide",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "author",
    "language",
    "summary",
    "requiredMods",
    "classTags",
    "createdAt",
    "updatedAt",
    "stages"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,79}$" },
    "title": { "type": "string", "minLength": 3, "maxLength": 120 },
    "author": { "type": "string", "minLength": 2, "maxLength": 80 },
    "language": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
    "summary": { "type": "string", "minLength": 10, "maxLength": 420 },
    "requiredMods": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/internalName" }
    },
    "classTags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/tag" }
    },
    "guideTags": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/tag" }
    },
    "createdAt": { "$ref": "#/$defs/date" },
    "updatedAt": { "$ref": "#/$defs/date" },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stage" }
    }
  },
  "$defs": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "internalName": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*$" },
    "contentId": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*/[A-Za-z][A-Za-z0-9_]*$" },
    "tag": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{1,39}$" },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "era", "items"],
      "properties": {
        "id": { "$ref": "#/$defs/tag" },
        "title": { "type": "string", "minLength": 3, "maxLength": 100 },
        "era": {
          "enum": ["prehardmode", "hardmode", "postmoonlord"]
        },
        "progressionMarkers": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/tag" }
        },
        "description": { "type": "string", "maxLength": 1800 },
        "bossRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/contentId" }
        },
        "goals": {
          "type": "array",
          "items": { "type": "string", "minLength": 3, "maxLength": 180 }
        },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/guideItem" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 3, "maxLength": 320 }
        }
      }
    },
    "guideItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["itemId", "category"],
      "properties": {
        "itemId": { "$ref": "#/$defs/contentId" },
        "category": {
          "enum": [
            "weapon",
            "armor",
            "accessory",
            "ammo",
            "tool",
            "mount",
            "pet",
            "buff",
            "material",
            "ore",
            "furniture",
            "other"
          ]
        },
        "priority": { "type": "integer", "minimum": 0, "maximum": 100 },
        "note": { "type": "string", "maxLength": 420 },
        "alternatives": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/contentId" }
        }
      }
    }
  }
}
